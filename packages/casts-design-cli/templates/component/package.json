{
  "name": "<%= name %>",
  "version": "<%= version %>",
  "description": "<%= description %>",
  "author": "<%- author %>",
  "license": "<%= license %>",
  "repository": "<%= repository %>",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "source": "src/index.tsx",
  "types": "dist/types/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "cd-tools build --esm --cjs",
    "build:types": "tsc --emitDeclarationOnly --outDir dist/types --noEmit false",
    "start": "cd-tools build  --esm --cjs --watch",
    "clean": "rimraf dist node_modules",
    "test": "run-s test:unit",
    "test:unit": "cd-tools test",
    "test:watch": "cd-tools test --watch",
    "test:coverage": "cd-tools test --coverage"
  },
  "peerDependencies": {
    "react": "^17.0.0",
    "react-dom": "^17.0.0"
  },
  "devDependencies": {
    "@casts/cd-standard": "workspace:^1.0.0",
    "@casts/cd-tools": "workspace:^1.0.0",
    "@svgr/cli": "^6.2.1",
    "@testing-library/dom": "^8.11.3",
    "@testing-library/jest-dom": "^4.2.4",
    "@testing-library/react": "^12.1.3",
    "@testing-library/user-event": "^7.2.1",
    "@types/jest": "^27.4.0",
    "@types/node": "^12.20.46",
    "@types/react": "^17.0.39",
    "@types/react-dom": "^17.0.11",
    "cross-env": "^7.0.3",
    "identity-obj-proxy": "^3.0.0",
    "npm-run-all": "^4.1.5",
    "react-test-renderer": "^17.0.2",
    "rimraf": "^3.0.2",
    "tslib": "^2.3.1"
  },
  "dependencies": {
  }
}
