{
  "private": true,
  "name": "dumi-app",
  "repository": "https://github.com/moecasts/casts-design",
  "scripts": {
    "start": "dumi dev",
    "build": "dumi build",
    "serve": "serve ./dist",
    "clean": "rimraf dist node_modules",
    "prettier": "prettier --write \"**/*.{js,jsx,tsx,ts,less,md,json}\"",
    "cli": "cd-cli",
    "lint": "run-s lint:js lint:css",
    "lint:js": "eslint .",
    "lint:css": "stylelint \"**/*.{css,scss,sass}\"",
    "prepare": "husky install"
  },
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "typings": "dist/index.d.ts",
  "engines": {
    "node": ">=14"
  },
  "sideEffects": false,
  "dependencies": {
    "@casts/message": "workspace:^0.0.1",
    "@casts/progress": "workspace:^0.0.1",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "react-router": "^6.3.0"
  },
  "peerDependencies": {
    "@casts/icons": "workspace:^1.0.0"
  },
  "devDependencies": {
    "@casts/alert": "workspace:^0.0.1",
    "@casts/button": "workspace:^1.0.0",
    "@casts/cd-cli": "workspace:^1.0.0",
    "@casts/cd-standard": "workspace:^1.0.0",
    "@casts/cd-tools": "workspace:^1.0.0",
    "@casts/icons": "workspace:^1.0.0",
    "@casts/notification": "workspace:^0.0.1",
    "@casts/theme": "workspace:^1.0.0",
    "@casts/typography": "workspace:^1.0.0",
    "@changesets/cli": "^2.22.0",
    "@umijs/plugin-esbuild": "^1.4.1",
    "@umijs/plugin-sass": "^1.1.1",
    "cz-conventional-changelog": "^3.3.0",
    "dumi": "^1.1.42",
    "husky": "^7.0.4",
    "lint-staged": "^10.5.4",
    "node": "link:@umijs/babel-preset-umi/node",
    "npm-run-all": "^4.1.5",
    "postcss-scss": "^4.0.4",
    "prettier": "^2.6.2",
    "rimraf": "^3.0.2",
    "serve": "^13.0.2",
    "stylelint": "^14.8.5",
    "stylelint-config-prettier": "^9.0.3",
    "tslib": "^2.4.0",
    "typescript": "^4.7.2",
    "umi": "^3.5.25",
    "webpack": "^5.73.0"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  }
}
