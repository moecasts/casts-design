{
  "private": true,
  "name": "dumi-app",
  "scripts": {
    "start": "dumi dev",
    "build": "dumi build",
    "prettier": "prettier --write \"**/*.{js,jsx,tsx,ts,less,md,json}\"",
    "cli": "cd-cli"
  },
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "typings": "dist/index.d.ts",
  "gitHooks": {
    "pre-commit": "lint-staged"
  },
  "lint-staged": {
    "*.{js,jsx,less,md,json}": [
      "prettier --write"
    ],
    "*.ts?(x)": [
      "prettier --parser=typescript --write"
    ]
  },
  "dependencies": {
    "@casts/cd-cli": "workspace:^1.0.0",
    "@casts/form": "workspace:^",
    "@casts/input": "workspace:^",
    "react": "^16.13.1",
    "react-dom": "^16.13.1",
    "react-router": "^6.2.1"
  },
  "devDependencies": {
    "dumi": "^1.0.13",
    "lint-staged": "^10.0.7",
    "prettier": "^2.2.1",
    "typescript": "^3.9.10",
    "yorkie": "^2.0.0"
  }
}
